{
	"manifest_version": 3,
    "name": "Dark Theme",
    "version": "0.0.1",
    "action": {
		"default_title": "Dark Theme",
		"default_popup": "index.html"
	},
    "permissions": [
		"scripting",
		"storage",
		"notifications",
		"tabs"
    ],
	"web_accessible_resources": [
		{
			"resources": ["css/*", "sitesTheme/*"],
			"matches": ["<all_urls>"]
		}
    ],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"]
		}
	],
	"host_permissions": [
		"<all_urls>"
	]
}
